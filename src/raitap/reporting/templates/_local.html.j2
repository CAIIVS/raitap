<section class="detail-section" id="transparency-section">
  <div class="section-heading">
    <p class="eyebrow">Transparency</p>
    <h2>Transparency Details</h2>
  </div>

  {% if view.global_groups %}
    <section class="subsection">
      <h3>Global</h3>
      {% for group in view.global_groups %}
        <article class="card compact-card">
          <h4>{{ group.heading }}</h4>
          {% for image in group.image_srcs %}<img class="figure" src="{{ image }}" alt="{{ group.heading }}">{% endfor %}
        </article>
      {% endfor %}
    </section>
  {% endif %}

  {% if view.aggregated_groups %}
    <section class="subsection">
      <h3>Aggregated</h3>
      {% for group in view.aggregated_groups %}
        <article class="card compact-card">
          <h4>{{ group.heading }}</h4>
          {% for image in group.image_srcs %}<img class="figure" src="{{ image }}" alt="{{ group.heading }}">{% endfor %}
        </article>
      {% endfor %}
    </section>
  {% endif %}

  <section class="subsection">
    <h3>Local</h3>
    {% if view.local_samples %}
      {% for sample in view.local_samples %}
        <article class="sample-card sample-card--{{ sample.bucket|bucket_class(sample.correct) }}" id="sample-{{ sample.sample_index }}">
          <header class="sample-header">
            <div>
              <span class="badge">{{ sample.bucket }}</span>
              <h4>Sample {{ sample.sample_index }}</h4>
              {% if sample.sample_id %}
                <p class="context-line">File: {{ sample.sample_id }}</p>
              {% endif %}
              {% if sample.predicted_class is not none or sample.target_class is not none or sample.confidence is not none %}
                <p>Model Prediction: {{ sample.predicted_class if sample.predicted_class is not none else "n/a" }} · Ground Truth: {{ sample.target_class if sample.target_class is not none else "n/a" }} · Confidence: {{ sample.confidence|fmt_num }}</p>
              {% endif %}
            </div>
          </header>
          <div class="explainer-grid">
            {% if sample.thumbnail_srcs %}
              <article class="explainer-card original-card">
                <img class="figure" src="{{ sample.thumbnail_srcs[0] }}" alt="Original sample {{ sample.sample_index }}">
                <h5>Original image</h5>
                <p class="context-line">Input sample</p>
              </article>
            {% endif %}
            {% for explainer in sample.explainers %}
              <article class="explainer-card">
                {% if explainer.image_srcs %}
                  <img class="figure" src="{{ explainer.image_srcs[0] }}" alt="{{ explainer.visualiser_name }}">
                {% endif %}
                <h5>{{ explainer.visualiser_name }}</h5>
                {% set algorithm = explainer.headline.get("algorithm", explainer.algorithm) %}
                {% set method_families = explainer.headline.get("method_families") %}
                {% if algorithm != "n/a" or method_families %}
                  <p class="context-line">
                    {% if algorithm != "n/a" %}{{ algorithm }}{% endif %}{% if algorithm != "n/a" and method_families %} · {% endif %}{% if method_families %}{{ method_families }}{% endif %}
                  </p>
                {% endif %}
                {% set visualiser_sign = explainer.context.get("visualiser_sign") %}
                {% set visualiser_method = explainer.context.get("visualiser_method") %}
                {% set layer_path = explainer.context.get("layer_path") %}
                {% if visualiser_sign or visualiser_method or layer_path %}
                  <p class="context-line">
                    {% if visualiser_sign %}{{ visualiser_sign }}{% endif %}{% if visualiser_sign and visualiser_method %} · {% endif %}{% if visualiser_method %}{{ visualiser_method }}{% endif %}{% if (visualiser_sign or visualiser_method) and layer_path %} · {% endif %}{% if layer_path %}{{ layer_path }}{% endif %}
                  </p>
                {% endif %}
                {% if explainer.technical %}
                  <details>
                    <summary>Technical details</summary>
                    <table>
                      <tbody>
                        {% for key, value in explainer.technical.items() %}
                          <tr><th>{{ key }}</th><td>{{ value }}</td></tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </details>
                {% endif %}
                <a class="text-link" href="#explainer-{{ explainer.explainer_name|slug }}">About this explainer</a>
                {% if explainer.baseline_image_src %}<a class="text-link" href="#baseline-{{ explainer.explainer_name|slug }}">View baseline</a>{% endif %}
              </article>
            {% endfor %}
          </div>
        </article>
      {% endfor %}
    {% else %}
      <p class="placeholder">No local explanations were configured for this run.</p>
    {% endif %}
  </section>

  {% include "_explainer_reference.html.j2" %}
</section>
