{% if view.robustness_assessors %}
  <section class="detail-section" id="robustness-section">
    <div class="section-heading">
      <p class="eyebrow">Robustness</p>
      <h2>Robustness Details</h2>
    </div>

    {% for assessor in view.robustness_assessors %}
      <article class="assessor-block" id="robustness-{{ assessor.assessor_name|slug }}">
        <header class="assessor-header">
          <div>
            <span class="badge">{{ assessor.method_kind }}</span>
            <h3>{{ assessor.assessor_name }}</h3>
          </div>
          <div class="badge-row">
            <span class="badge">{{ assessor.settings.get("threat_model", "n/a") }}</span>
            <span class="badge">{{ assessor.settings.get("objective", "n/a") }}</span>
            <span class="badge">{{ assessor.settings.get("norm", "n/a") }}={{ assessor.settings.get("epsilon", "n/a") }}</span>
          </div>
        </header>

        <div class="metric-grid metric-grid--wide">
          {% for key in ["clean_accuracy", "adversarial_accuracy", "attack_success_rate", "mean_distance", "max_distance"] %}
            <div class="tile"><span>{{ key }}</span><strong>{{ assessor.metrics.get(key, "n/a")|fmt_num }}</strong></div>
          {% endfor %}
        </div>

        {% for sample in assessor.samples %}
          <section class="robust-row">
            <h4>Sample {{ sample.sample_index }}</h4>
            <div class="robust-images">
              {% if sample.image_pair_src %}
                <figure><img class="figure" src="{{ sample.image_pair_src }}" alt="Clean and adversarial sample {{ sample.sample_index }}"><figcaption>Clean vs adversarial</figcaption></figure>
              {% endif %}
              {% if sample.perturbation_heatmap_src %}
                <figure><img class="figure" src="{{ sample.perturbation_heatmap_src }}" alt="Perturbation heatmap sample {{ sample.sample_index }}"><figcaption>Perturbation</figcaption></figure>
              {% endif %}
            </div>
          </section>
        {% endfor %}

        <details>
          <summary>Full settings</summary>
          <table>
            <tbody>
              {% for key, value in assessor.rows %}
                <tr><th>{{ key }}</th><td>{{ value }}</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </details>
      </article>
    {% endfor %}
  </section>
{% endif %}
